# Nidham configuration. Copy to `.env` and fill in. Anything left unset degrades
# gracefully — the app runs as a local, single-user demo with a built-in fallback
# plan, so it never breaks without services.

# ── Agent (one swappable module) ────────────────────────────────────────────────
# "webhook" (preferred — key stays server-side on n8n) | "direct" (model key below)
EXPO_PUBLIC_AGENT_MODE=webhook
# n8n webhook that runs Triage → Planner → Breakdown (and, later, the agent tools).
EXPO_PUBLIC_AGENT_URL=https://your-n8n-host/webhook/nidham
# Only used in "direct" mode. Never commit a real key.
EXPO_PUBLIC_AGENT_KEY=

# ── Supabase (Postgres + Auth) ──────────────────────────────────────────────────
# If both are set, the app requires sign-in and syncs items to Postgres (per-user,
# RLS-protected). If unset, the app runs locally with no auth. See docs/supabase.md.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
